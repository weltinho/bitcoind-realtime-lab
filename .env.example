# Opcional: hosts HTTPS do Caddy (tls internal). Para abrir por https://IP_PUBLICO na EC2,
# acrescente o IPv4 à lista, ex.:
# CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1], 3.14.159.26
CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1]

BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=bitcoinrpcdevpassword
BITCOIN_HOST=bitcoind
BITCOIN_RPC_PORT=18443
BITCOIN_NETWORK=regtest
BITCOIN_ZMQ_BLOCK_PORT=28332
BITCOIN_ZMQ_TX_PORT=28333
