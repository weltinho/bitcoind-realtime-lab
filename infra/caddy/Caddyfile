# :80 e :443 escutam em todas as interfaces do container (0.0.0.0).
# Assim o mapeamento Docker "80:80" / "443:443" recebe tráfego externo (IP público da EC2)
# e também continua funcionando com https://localhost no seu notebook.

:80 {
	redir https://{host}{uri}
}

:443 {
	tls internal

	# Todas as chamadas da API passam pelo backend.
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	# WebSocket de eventos em tempo real.
	handle /ws/* {
		reverse_proxy backend:8000
	}

	# Frontend React (Vite dev server no container frontend).
	handle {
		reverse_proxy frontend:5173
	}
}
